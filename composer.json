{
    "name": "paranoiq/timeshit",
    "description": "Personal time tracker integrating YouTrack, GitLab, and Git.",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-ffi": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Timeshit\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "ps": "vendor/bin/phpstan analyse | ../../../flowbox/flowbox-laravel/tooling/phpstan-tweak.php"
    }
}